{
  "name": "team-directory-backend",
  "version": "1.0.0",
  "description": "Team Directory Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.js --watchAll=false --runInBand --detectOpenHandles",
    "test:watch": "jest --config jest.config.js --watch --runInBand --detectOpenHandles",
    "test:ci": "npm run test:db:reset && npm run test:db:seed && npm run test:ci",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --config jest.config.js --runInBand --detectOpenHandles",
    "test:setup": "npm install && npm run prisma:generate && npm run prisma:migrate",
    "test:reset": "prisma migrate reset --force && npm run test:setup",
    "test:db:setup": "prisma migrate deploy && npm run prisma:generate",
    "test:db:reset": "prisma migrate reset --force && npm run test:db:setup",
    "test:db:seed": "ts-node src/tests/seed.ts",
    "test:all": "npm run test:db:reset && npm run test:db:seed && npm test",
    "test:full": "npm run test:db:reset && npm run test:db:seed && npm test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.8.1",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.3",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0",
    "prisma": "^5.8.1",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.5",
    "@types/supertest": "^2.0.12",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
