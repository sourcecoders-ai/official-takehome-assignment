{
  "name": "team-directory",
  "version": "1.0.0",
  "scripts": {
    "backend": "cd backend && npm run",
    "test": "npm run backend test",
    "test:all": "cd backend && npm run test:all --if-present",
    "test:ci": "npm run backend test:ci",
    "test:watch": "npm run backend test:watch",
    "test:debug": "npm run backend test:debug",
    "test:setup": "npm run backend test:setup",
    "test:reset": "npm run backend test:reset",
    "test:db:setup": "npm run backend test:db:setup",
    "test:db:reset": "cd backend && npm run test:db:reset --if-present",
    "test:db:seed": "cd backend && npm run test:db:seed --if-present",
    "test:full": "npm run backend test:full",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "prisma:generate": "npm run backend prisma:generate",
    "prisma:migrate": "npm run backend prisma:migrate",
    "prisma:studio": "npm run backend prisma:studio",
    "seed": "cd backend && npx ts-node src/seed.ts"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.3",
    "express-validator": "^7.2.1",
    "morgan": "^1.10.0"
  }
}
